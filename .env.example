APP_NAME=Habit Tracker Bot
ENVIRONMENT=development
LOG_LEVEL=INFO

BOT_TOKEN=replace_with_your_telegram_bot_token

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=habit_tracker
POSTGRES_USER=habit_user
POSTGRES_PASSWORD=habit_password
DATABASE_ECHO=false

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_ENABLED=true
CELERY_BROKER_DB=1
CELERY_RESULT_DB=2

API_HOST=0.0.0.0
API_PORT=8000
